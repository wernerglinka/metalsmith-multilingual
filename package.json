{
  "name": "metalsmith-i18n",
  "version": "0.0.2",
  "description": "A Metalsmith plugin that adds internationalization metadata to files based on directory structure and frontmatter alternate links",
  "type": "module",
  "main": "./src/index.js",
  "exports": "./src/index.js",
  "engines": {
    "node": ">= 18.0.0"
  },
  "scripts": {
    "changelog": "auto-changelog -u --commit-limit false --ignore-commit-pattern '^((dev|chore|ci):|Release)'",
    "coverage": "./scripts/test.sh --test-reporter=lcov --test-reporter-destination=coverage/lcov.info --test-reporter=spec --test-reporter-destination=stdout",
    "format": "prettier --write \"**/*.{yml,md,js,json}\"",
    "format:check": "prettier --list-different \"**/*.{yml,md,js,json}\"",
    "lint": "eslint --fix .",
    "lint:check": "eslint --fix-dry-run .",
    "release:patch": "./scripts/release.sh patch --ci",
    "release:minor": "./scripts/release.sh minor --ci",
    "release:major": "./scripts/release.sh major --ci",
    "release:check": "npm run lint:check && release-it --dry-run",
    "test": "./scripts/test.sh",
    "test:unit": "node --test test/unit/dot-path.test.js test/unit/locale-detector.test.js test/unit/hreflang-builder.test.js",
    "test:esm": "node --test test/index.test.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wernerglinka/metalsmith-i18n"
  },
  "keywords": [
    "metalsmith",
    "metalsmith-plugin",
    "i18n",
    "internationalization",
    "localization",
    "hreflang",
    "multilingual"
  ],
  "files": [
    "src",
    "LICENSE",
    "README.md"
  ],
  "author": "Werner Glinka <werner@glinka.co>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/wernerglinka/metalsmith-i18n/issues"
  },
  "homepage": "https://github.com/wernerglinka/metalsmith-i18n",
  "devDependencies": {
    "auto-changelog": "^2.5.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.3",
    "metalsmith": "^2.6.3",
    "prettier": "^3.5.3",
    "release-it": "^19.0.2"
  },
  "peerDependencies": {
    "metalsmith": "^2.5.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
